# 基础配置
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
PROJECT_NAME=SmartHr

# 数据库配置
# 默认使用SQLite，不需要修改，如果需要切换到MySQL取消下面注释
# SQLALCHEMY_DATABASE_URL=mysql+pymysql://user:password@localhost:3306/smarthr

# JWT配置
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 火山引擎大模型配置
VOLCENGINE_API_KEY=your-volcengine-api-key-here
VOLCENGINE_MODEL=doubao-1.5-pro-250115

# 上传配置
MAX_FILE_SIZE=10485760
